{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epicollect.net/schemas/file-entry-payload/v1.0.0",
  "title": "Epicollect5 File Entry Upload Payload",
  "description": "Schema for the JSON body carried in the data field of multipart file uploads.",
  "type": "object",
  "required": [
    "data"
  ],
  "properties": {
    "data": {
      "$ref": "#/$defs/fileEntryEnvelope"
    }
  },
  "unevaluatedProperties": false,
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "formRef": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}_[a-f0-9]{13}$"
    },
    "inputRef": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}(_[a-f0-9]{13}){2,}$"
    },
    "optionalFormRef": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "$ref": "#/$defs/formRef"
        }
      ]
    },
    "optionalInputRef": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "$ref": "#/$defs/inputRef"
        }
      ]
    },
    "optionalUuid": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "$ref": "#/$defs/uuid"
        }
      ]
    },
    "projectVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
    },
    "isoInstant": {
      "type": "string",
      "format": "date-time"
    },
    "attributes": {
      "type": "object",
      "required": [
        "form"
      ],
      "properties": {
        "form": {
          "type": "object",
          "required": [
            "ref",
            "type"
          ],
          "properties": {
            "ref": {
              "$ref": "#/$defs/formRef"
            },
            "type": {
              "const": "hierarchy"
            }
          },
          "unevaluatedProperties": false
        }
      },
      "unevaluatedProperties": false
    },
    "relationships": {
      "type": "object",
      "required": [
        "parent",
        "branch"
      ],
      "properties": {
        "parent": {
          "oneOf": [
            {
              "type": "object",
              "maxProperties": 0
            },
            {
              "type": "object",
              "required": [
                "data"
              ],
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "parent_form_ref",
                    "parent_entry_uuid"
                  ],
                  "properties": {
                    "parent_form_ref": {
                      "$ref": "#/$defs/optionalFormRef"
                    },
                    "parent_entry_uuid": {
                      "$ref": "#/$defs/optionalUuid"
                    }
                  },
                  "unevaluatedProperties": false
                }
              },
              "unevaluatedProperties": false
            }
          ]
        },
        "branch": {
          "oneOf": [
            {
              "type": "object",
              "maxProperties": 0
            },
            {
              "type": "object",
              "required": [
                "data"
              ],
              "properties": {
                "data": {
                  "type": "object",
                  "required": [
                    "owner_input_ref",
                    "owner_entry_uuid"
                  ],
                  "properties": {
                    "owner_input_ref": {
                      "$ref": "#/$defs/optionalInputRef"
                    },
                    "owner_entry_uuid": {
                      "$ref": "#/$defs/optionalUuid"
                    }
                  },
                  "unevaluatedProperties": false
                }
              },
              "unevaluatedProperties": false
            }
          ]
        }
      },
      "unevaluatedProperties": false
    },
    "fileEntry": {
      "type": "object",
      "required": [
        "entry_uuid",
        "name",
        "type",
        "input_ref",
        "project_version"
      ],
      "properties": {
        "entry_uuid": {
          "$ref": "#/$defs/uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "audio",
            "video",
            "photo"
          ]
        },
        "input_ref": {
          "$ref": "#/$defs/inputRef"
        },
        "project_version": {
          "$ref": "#/$defs/projectVersion"
        },
        "created_at": {
          "$ref": "#/$defs/isoInstant"
        },
        "device_id": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        }
      },
      "unevaluatedProperties": false
    },
    "fileEntryEnvelope": {
      "type": "object",
      "required": [
        "type",
        "id",
        "attributes",
        "relationships",
        "file_entry"
      ],
      "properties": {
        "type": {
          "const": "file_entry"
        },
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "attributes": {
          "$ref": "#/$defs/attributes"
        },
        "relationships": {
          "$ref": "#/$defs/relationships"
        },
        "file_entry": {
          "$ref": "#/$defs/fileEntry"
        }
      },
      "unevaluatedProperties": false,
      "$comment": "Application logic must ensure data.id matches data.file_entry.entry_uuid."
    }
  }
}
